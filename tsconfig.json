{
  // Visit https://aka.ms/tsconfig to read more about this file
  "compilerOptions": {
    "target": "esnext",
    "module": "esnext",
    "moduleResolution": "bundler",
    "strict": true,
    "jsx": "react-jsx",
    "skipLibCheck": true,
    "types": ["chrome", "vite/client"],
    "noEmit": true,
    "isolatedModules": true
  },
  "include": ["src", "vite.config.ts", "manifest.json"]
}
